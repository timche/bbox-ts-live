# The service has two independent features: Broadcast Box and Twitch. Configure
# either one, or both — at least one is required. A feature is enabled only when
# all of its variables are set.

# ---- Broadcast Box (optional feature) ----
# Enabled when API_URL + ADMIN_TOKEN + PUBLIC_STREAM_HOST are all set.
# Internal base URL of the Broadcast Box API (no trailing slash).
# In the example compose this is the private service name.
BROADCAST_BOX_API_URL=http://broadcast-box:8080

# Admin token in CLEARTEXT. The watcher base64-encodes it automatically before
# sending it as `Authorization: Bearer <base64(token)>`.
# Must equal Broadcast Box's FRONTEND_ADMIN_TOKEN.
BROADCAST_BOX_ADMIN_TOKEN=changeme

# Public host used in the per-user stream-link group name, e.g.
# "📺 stream.example.com/azn". Scheme (https://) and trailing slashes are
# stripped automatically.
PUBLIC_STREAM_HOST=stream.example.com

# ---- Twitch (optional feature) ----
# Enabled when both CLIENT_ID and CLIENT_SECRET are set (they must be set
# together). Create an app at https://dev.twitch.tv/console/apps to get them.
# Instead of matching stream keys to nicknames, this checks pre-assigned
# "twitch.tv/<username>" TeamSpeak server groups (admins create/assign these)
# and gives the members of live channels the shared live group below.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Name of the shared Twitch "live" group. Auto-created with "show name in tree:
# before", so it renders as e.g. "🟣 azn" in the tree.
TWITCH_LIVE_GROUP_NAME=🟣
# Prefix of the pre-assigned per-user Twitch groups; the username is the part
# after it (e.g. "twitch.tv/azn" -> "azn").
TWITCH_GROUP_PREFIX=twitch.tv/
# Message posted to the channel a user is in when they go live on Twitch.
# Supports "{nickname}" and "{link}" (e.g. https://twitch.tv/azn). Blank disables.
TWITCH_LIVE_MESSAGE_TEMPLATE={nickname} is now live: {link}

# ---- TeamSpeak ServerQuery ----
TEAMSPEAK_HOST=teamspeak
# ServerQuery (RAW) port.
TEAMSPEAK_QUERY_PORT=10011
# Voice port of the virtual server to select.
TEAMSPEAK_SERVER_PORT=9987
TEAMSPEAK_QUERY_USERNAME=serveradmin
TEAMSPEAK_QUERY_PASSWORD=changeme
# Nickname the query client connects with.
TEAMSPEAK_QUERY_NICKNAME=bbox-ts-live

# ---- Watcher ----
# Reconcile interval in milliseconds (shared by both features).
POLL_INTERVAL_MS=10000
# Broadcast Box only — name of its shared "live" group. Auto-created with
# "show name in tree: before", so it renders as e.g. "🔴 alice" in the tree.
LIVE_GROUP_NAME=🔴
# Broadcast Box only — prefix for the per-user stream-link groups
# (e.g. "📺 stream.example.com/azn").
STREAM_GROUP_PREFIX=📺
# Broadcast Box only — message posted to the channel a user is in when they go
# live. Supports "{nickname}" (their TeamSpeak nickname) and "{link}" (the
# public stream URL, e.g. https://stream.example.com/azn). Blank disables it.
LIVE_MESSAGE_TEMPLATE={nickname} is now live: {link}
# debug | info | warn | error
LOG_LEVEL=info
